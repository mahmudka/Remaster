@page "/progress/{JobId}"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject SignalRService SignalR

<PageTitle>Обработка — @JobId</PageTitle>

<MudGrid Spacing="4">

    <!-- Header -->
    <MudItem xs="12">
        <MudText Typo="Typo.h5" Class="mb-1">Обработка трека</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family:monospace;">
            job/@JobId
        </MudText>
    </MudItem>

    <!-- Progress card -->
    <MudItem xs="12" md="8">
        <MudPaper Class="glass-card pa-5" Elevation="0">

            <!-- Steps -->
            <div style="display:flex; gap:32px; margin-bottom:28px;">
                @foreach (var step in _steps)
                {
                    <div style="display:flex; align-items:center; gap:8px; opacity:@(step.Active ? "1" : "0.4");">
                        <div class="step-dot @step.DotClass"></div>
                        <MudText Typo="Typo.caption" Style="@(step.Active ? "color:#c4b5fd;" : "")">
                            @step.Name
                        </MudText>
                    </div>
                }
            </div>

            <!-- Current status -->
            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color:#e2e8f0;">
                @CurrentBlock
            </MudText>
            <MudProgressLinear Value="@ProgressValue" Color="Color.Primary"
                               Rounded="true" Size="Size.Medium" Class="mb-1" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">@ProgressValue%</MudText>
        </MudPaper>
    </MudItem>

    <!-- Log card -->
    <MudItem xs="12" md="8">
        <MudPaper Class="glass-card pa-4" Elevation="0">
            <MudText Typo="Typo.overline"
                     Style="color:#4b5563; letter-spacing:2px; font-size:10px;" Class="mb-3 d-block">
                ЛОГ
            </MudText>
            <div class="log-box">
                <ProgressLog Entries="@LogEntries" />
            </div>
        </MudPaper>
    </MudItem>

    @if (IsDone)
    {
        <MudItem xs="12">
            <MudButton Variant="Variant.Filled" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.CheckCircleOutline"
                       Style="border-radius:12px; font-weight:600;"
                       OnClick="@(() => Nav.NavigateTo($"/result/{JobId}"))">
                Смотреть результат
            </MudButton>
        </MudItem>
    }

</MudGrid>

@code {
    [Parameter] public string JobId { get; set; } = "";

    int    ProgressValue = 0;
    string CurrentBlock  = "Подключение...";
    bool   IsDone        = false;

    List<ProgressLog.LogEntry> LogEntries = new();

    record StepInfo(string Name, string Block)
    {
        public bool   Active   { get; set; }
        public string DotClass { get; set; } = "";
    }

    List<StepInfo> _steps = new()
    {
        new("Анализ",    "AnalysisAgent"),
        new("План",      "PlanAgent"),
        new("Мастеринг", "MasteringAgent"),
    };

    protected override async Task OnInitializedAsync()
    {
        SignalR.OnProgress += OnProgressReceived;
        await SignalR.ConnectAsync();
        await SignalR.JoinJobAsync(JobId);
    }

    void OnProgressReceived(AudioPipeline.Shared.DTOs.ProgressDto dto)
    {
        LogEntries.Add(new(dto.Block, dto.Status, dto.Message, dto.Timestamp));
        ProgressValue = dto.ProgressPercent;
        CurrentBlock  = dto.Message;

        foreach (var step in _steps)
        {
            if (step.Block == dto.Block)
            {
                step.Active   = true;
                step.DotClass = dto.Status switch
                {
                    "done"    => "done",
                    "error"   => "error",
                    "running" => "running",
                    _         => "running",
                };
            }
        }

        if (dto.Block == "Pipeline" && dto.Status == "done" && dto.ProgressPercent >= 100)
        {
            IsDone = true;
            foreach (var s in _steps) { s.Active = true; s.DotClass = "done"; }
            bool hasErrors = LogEntries.Any(e => e.Status == "error");
            if (!hasErrors)
                InvokeAsync(() => Nav.NavigateTo($"/result/{JobId}"));
        }
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        SignalR.OnProgress -= OnProgressReceived;
        await SignalR.LeaveJobAsync(JobId);
        await SignalR.DisposeAsync();
    }
}
