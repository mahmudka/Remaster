@page "/voice-models"
@rendermode InteractiveServer
@inject PipelineService PipelineService
@inject ISnackbar Snackbar

<PageTitle>Голосовые модели</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Голосовые модели RVC</MudText>

<MudGrid>
    <!-- ── Model list ───────────────────────────────────────────── -->
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Загруженные модели</MudText>

            @if (!Models.Any())
            {
                <MudAlert Severity="Severity.Info" Class="mb-2">
                    Нет загруженных моделей. Добавь модель справа.
                </MudAlert>
            }
            else
            {
                <MudTable Items="@Models" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Название</MudTh>
                        <MudTh>Путь</MudTh>
                        <MudTh>По умолч.</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudText Typo="Typo.body2"><b>@context.Name</b></MudText>
                            @if (context.Description is not null)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <MudTooltip Text="@context.ModelPath">
                                <MudText Typo="Typo.caption">@System.IO.Path.GetFileName(context.ModelPath)</MudText>
                            </MudTooltip>
                        </MudTd>
                        <MudTd>
                            @if (context.IsDefault)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Default</MudChip>
                            }
                            else
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Text"
                                           OnClick="@(() => SetDefaultAsync(context.Id))">
                                    Сделать Default
                                </MudButton>
                            }
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteAsync(context.Id))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>

    <!-- ── Add model form ───────────────────────────────────────── -->
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Добавить модель</MudText>

            <MudTextField @bind-Value="NewName" Label="Название модели"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-2" />
            <MudTextField @bind-Value="NewModelPath" Label="Путь к .pth файлу"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-2"
                          HelperText="Пример: C:\Models\vocals_model.pth" />
            <MudTextField @bind-Value="NewIndexPath" Label="Путь к .index файлу (опционально)"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-2" />
            <MudTextField @bind-Value="NewDescription" Label="Описание"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-3" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true"
                       Disabled="@(string.IsNullOrWhiteSpace(NewName) || string.IsNullOrWhiteSpace(NewModelPath))"
                       OnClick="AddModelAsync">
                Добавить модель
            </MudButton>
        </MudPaper>

        <!-- RVC status -->
        <MudPaper Class="pa-4 mt-3" Outlined="true">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Статус сервиса RVC (:8004)</MudText>
            @if (RvcStatus is null)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Проверяется...</MudText>
            }
            else if (RvcStatus.Value)
            {
                <MudChip T="string" Color="Color.Success" Size="Size.Small">Online</MudChip>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">
                    rvc-python: @(RvcLibOk ? "установлен" : "не установлен (fallback pitch-shift)")
                </MudText>
            }
            else
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small">Offline</MudChip>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Запусти сервис: python services\python_rvc\main.py
                </MudText>
            }

            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 d-block">
                Установка rvc-python (если нужно):
            </MudText>
            <MudText Typo="Typo.caption" Style="font-family:monospace">
                pip install rvc-python
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    List<AudioPipeline.Shared.Models.VoiceModel> Models = new();
    bool?   RvcStatus  = null;
    bool    RvcLibOk   = false;

    string NewName        = "";
    string NewModelPath   = "";
    string NewIndexPath   = "";
    string NewDescription = "";

    protected override async Task OnInitializedAsync()
    {
        Models = await PipelineService.GetVoiceModelsAsync();
        await CheckRvcServiceAsync();
    }

    async Task CheckRvcServiceAsync()
    {
        try
        {
            var (ok, libOk) = await PipelineService.CheckRvcServiceAsync();
            RvcStatus = ok;
            RvcLibOk  = libOk;
        }
        catch
        {
            RvcStatus = false;
        }
    }

    async Task AddModelAsync()
    {
        try
        {
            await PipelineService.AddVoiceModelAsync(NewName, NewModelPath,
                string.IsNullOrWhiteSpace(NewIndexPath) ? null : NewIndexPath,
                string.IsNullOrWhiteSpace(NewDescription) ? null : NewDescription);
            Models = await PipelineService.GetVoiceModelsAsync();
            NewName = NewModelPath = NewIndexPath = NewDescription = "";
            Snackbar.Add("Модель добавлена", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
    }

    async Task DeleteAsync(int id)
    {
        await PipelineService.DeleteVoiceModelAsync(id);
        Models = await PipelineService.GetVoiceModelsAsync();
        Snackbar.Add("Модель удалена", Severity.Info);
    }

    async Task SetDefaultAsync(int id)
    {
        await PipelineService.SetDefaultVoiceModelAsync(id);
        Models = await PipelineService.GetVoiceModelsAsync();
        Snackbar.Add("Модель по умолчанию обновлена", Severity.Success);
    }
}
