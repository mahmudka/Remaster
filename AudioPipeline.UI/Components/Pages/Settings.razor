@page "/settings"
@rendermode InteractiveServer
@inject IConfiguration Config
@inject ISnackbar Snackbar

<PageTitle>Настройки</PageTitle>

<MudGrid Spacing="4">

    <MudItem xs="12">
        <MudText Typo="Typo.h5" Class="mb-1">Настройки</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Параметры обработки и пути к файлам.
        </MudText>
    </MudItem>

    <!-- Целевая громкость -->
    <MudItem xs="12" md="6">
        <MudPaper Class="glass-card pa-5" Elevation="0">
            <MudText Typo="Typo.overline"
                     Style="color:#4b5563; letter-spacing:2px; font-size:10px;" Class="mb-4 d-block">
                ЦЕЛЕВАЯ ГРОМКОСТЬ
            </MudText>

            <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:20px;">
                @foreach (var preset in _lufsPresets)
                {
                    <div @onclick="@(() => SelectPreset(preset.Value))"
                         style="display:flex; align-items:center; justify-content:space-between;
                                padding:12px 16px; border-radius:10px; cursor:pointer;
                                border:1px solid @(TargetLufs == preset.Value ? "#8b5cf6" : "rgba(255,255,255,0.08)");
                                background:@(TargetLufs == preset.Value ? "rgba(139,92,246,0.12)" : "transparent");
                                transition:all 0.15s;">
                        <MudText Typo="Typo.body2" Style="@(TargetLufs == preset.Value ? "color:#c4b5fd;" : "")">
                            @preset.Label
                        </MudText>
                        <MudText Typo="Typo.caption" Style="font-family:monospace; color:#94a3b8;">
                            @preset.Value LUFS
                        </MudText>
                    </div>
                }
            </div>

            <MudDivider Class="mb-4" />

            <MudText Typo="Typo.body2" Class="mb-2">
                Своё значение: <b style="color:#a78bfa;">@TargetLufs LUFS</b>
            </MudText>
            <MudSlider @bind-Value="TargetLufs" Min="-23" Max="-8" Step="1"
                       Color="Color.Primary" />
            <div style="display:flex; justify-content:space-between; margin-top:4px;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">−23 (тихо)</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">−8 (громко)</MudText>
            </div>
        </MudPaper>
    </MudItem>

    <!-- Папки и сервис -->
    <MudItem xs="12" md="6">
        <div style="display:flex; flex-direction:column; gap:16px;">

            <MudPaper Class="glass-card pa-5" Elevation="0">
                <MudText Typo="Typo.overline"
                         Style="color:#4b5563; letter-spacing:2px; font-size:10px;" Class="mb-4 d-block">
                    ВЫХОДНАЯ ПАПКА
                </MudText>
                <MudTextField @bind-Value="OutputFolder" Label="Путь к папке"
                              Variant="Variant.Outlined" FullWidth="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Folder"
                              Style="font-family:monospace; font-size:13px;" />
            </MudPaper>

            <MudPaper Class="glass-card pa-5" Elevation="0">
                <MudText Typo="Typo.overline"
                         Style="color:#4b5563; letter-spacing:2px; font-size:10px;" Class="mb-4 d-block">
                    PYTHON СЕРВИС
                </MudText>
                <MudTextField @bind-Value="AudioServiceUrl" Label="python_audio URL"
                              Variant="Variant.Outlined" FullWidth="true" Class="mb-3"
                              Style="font-family:monospace; font-size:13px;" />

                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Outlined.Wifi"
                           OnClick="CheckService" Style="border-radius:8px;">
                    Проверить сервис
                </MudButton>

                @if (_serviceChecked)
                {
                    <div style="display:flex; align-items:center; gap:8px; margin-top:12px;">
                        <MudIcon Icon="@(_serviceOk ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Error)"
                                 Style="@(_serviceOk ? "color:#10b981;" : "color:#ef4444;")"
                                 Size="Size.Small" />
                        <MudText Typo="Typo.body2" Style="@(_serviceOk ? "color:#10b981;" : "color:#ef4444;")">
                            @(_serviceOk ? "Сервис работает" : "Сервис недоступен")
                        </MudText>
                    </div>
                }
            </MudPaper>

        </div>
    </MudItem>

    <!-- Save -->
    <MudItem xs="12">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Style="min-width:160px; border-radius:12px; font-weight:600;"
                   OnClick="Save">
            Сохранить
        </MudButton>
    </MudItem>

</MudGrid>

@code {
    int    TargetLufs     = -14;
    string OutputFolder   = System.IO.Path.Combine(System.IO.Path.GetTempPath(), "AudioPipeline");
    string AudioServiceUrl = "http://localhost:8001";

    bool _serviceChecked;
    bool _serviceOk;

    record LufsPreset(string Label, int Value);

    List<LufsPreset> _lufsPresets =
    [
        new("Spotify / YouTube",  -14),
        new("Apple Music",        -16),
        new("Broadcast (-23 EBU)", -23),
    ];

    protected override void OnInitialized()
    {
        TargetLufs      = int.TryParse(Config["Pipeline:TargetLufs"], out var l) ? l : -14;
        OutputFolder    = Config["Pipeline:OutputFolder"] ?? OutputFolder;
        AudioServiceUrl = Config["Microservices:AudioUrl"]  ?? AudioServiceUrl;
    }

    void SelectPreset(int value) => TargetLufs = value;

    async Task CheckService()
    {
        _serviceChecked = false;
        var http = new System.Net.Http.HttpClient { Timeout = TimeSpan.FromSeconds(3) };
        try
        {
            var r = await http.GetAsync(AudioServiceUrl + "/health");
            _serviceOk = r.IsSuccessStatusCode;
        }
        catch { _serviceOk = false; }
        _serviceChecked = true;
        StateHasChanged();
    }

    void Save()
    {
        Snackbar.Add("Настройки сохранены (перезапустите приложение для применения)", Severity.Info);
    }
}
